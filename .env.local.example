# Copy this file to `.env.local` in the project root and fill in real values.
# Do not commit `.env.local`.

MONGO_URI=mongodb+srv://<username>:<url_encoded_password>@<cluster-host>/<database>?appName=<app-name>
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
PORT=8080
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.*:5173,http://10.*:5173,http://172.16.*:5173
VITE_API_URL=http://localhost:8080
